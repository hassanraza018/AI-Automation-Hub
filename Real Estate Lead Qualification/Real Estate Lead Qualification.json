    {
      "parameters": {
        "jsCode": "const fields = $json.body.data.fields;\nconst result = {};\n\nfor (const field of fields) {\n  let value = field.value;\n\n  if ((field.type === \"DROPDOWN\" || field.type === \"MULTIPLE_CHOICE\") && Array.isArray(value) && field.options) {\n    const selectedId = value[0];\n    const matchedOption = field.options.find(opt => opt.id === selectedId);\n    value = matchedOption ? matchedOption.text : selectedId;\n  } \n  else if (Array.isArray(value)) {\n    value = value.join(\", \");\n  }\n\n  result[field.label] = value;\n}\n\nreturn result;"
      },
